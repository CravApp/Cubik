<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║              AndroidManifest.xml – KUBIK TASKS                      ║
  ║                                                                      ║
  ║  PERMISOS CRÍTICOS DOCUMENTADOS:                                     ║
  ║                                                                      ║
  ║  1. SCHEDULE_EXACT_ALARM / USE_EXACT_ALARM                          ║
  ║     → Requerido para alarmas exactas en Android 12+ (API 31+).      ║
  ║     → Sin esto, las alarmas pueden retrasarse hasta 10 minutos       ║
  ║       (Android Doze mode).                                          ║
  ║     → USE_EXACT_ALARM: automático, pero solo para apps de relojes   ║
  ║     → SCHEDULE_EXACT_ALARM: requiere consentimiento del usuario      ║
  ║                                                                      ║
  ║  2. RECEIVE_BOOT_COMPLETED                                           ║
  ║     → Las alarmas programadas se pierden al reiniciar el            ║
  ║       dispositivo. Este permiso permite reprogramarlas al boot.     ║
  ║                                                                      ║
  ║  3. VIBRATE                                                          ║
  ║     → Para vibración en notificaciones y alarmas.                   ║
  ║                                                                      ║
  ║  4. POST_NOTIFICATIONS                                               ║
  ║     → Obligatorio en Android 13+ (API 33+) para mostrar            ║
  ║       notificaciones. El SDK lo solicita en tiempo de ejecución.    ║
  ║                                                                      ║
  ║  5. USE_FULL_SCREEN_INTENT                                           ║
  ║     → Permite que la alarma urgente aparezca sobre la pantalla      ║
  ║       de bloqueo. Requiere revisión manual en Google Play Store      ║
  ║       a partir de Android 14 (API 34).                              ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══════════════════════════════════════════════════════════
         PERMISOS DE NOTIFICACIONES Y ALARMAS
         ═══════════════════════════════════════════════════════════ -->

    <!-- Android 13+ (API 33+): Permiso para mostrar notificaciones -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Android 12+ (API 31+): Alarmas exactas (el usuario puede revocar) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <!-- Alternativa más restrictiva para apps de reloj/alarma/calendario -->
    <!-- <uses-permission android:name="android.permission.USE_EXACT_ALARM"/> -->

    <!-- Vibración en notificaciones -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Recibir broadcast al inicio del dispositivo (reprogramar alarmas) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Alarmas urgentes: mostrar sobre la pantalla de bloqueo -->
    <!-- NOTA: A partir de Android 14, Google Play puede requerir justificación -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>

    <!-- Mantener la CPU activa mientras se procesa la alarma -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- ═══════════════════════════════════════════════════════════
         PERMISOS DE RED (para futuras integraciones de API)
         ═══════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:label="Kubik"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="false"
        android:requestLegacyExternalStorage="false">

        <!-- ══════════════════════════════════════════════════════
             ACTIVIDAD PRINCIPAL
             ══════════════════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:showWhenLocked="true"
            android:turnScreenOn="true">
            <!-- showWhenLocked + turnScreenOn: permiten que las alarmas
                 urgentes aparezcan sobre la pantalla de bloqueo -->

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Deep linking para respuesta a notificaciones -->
            <intent-filter>
                <action android:name="FLUTTER_NOTIFICATION_CLICK"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════════
             RECEPTORES DE BROADCAST (flutter_local_notifications)
             ══════════════════════════════════════════════════════ -->

        <!-- Receptor de alarmas programadas (AlarmManager) -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false"/>

        <!-- Receptor para reprogramar alarmas tras reinicio del dispositivo -->
        <!-- CRÍTICO: Sin este receiver, todas las alarmas se pierden al reiniciar -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <!-- Para dispositivos Samsung -->
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Receptor de acciones de notificación (dismiss, snooze, etc.) -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ActionBroadcastReceiver"
            android:exported="false"/>

        <!-- ══════════════════════════════════════════════════════
             META-DATA DE FLUTTER
             ══════════════════════════════════════════════════════ -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>

        <!-- Iconos de notificación personalizados (para Android 5+) -->
        <!-- El icono debe ser blanco sobre fondo transparente (.png) -->
        <meta-data
            android:name="com.dexterous.flutterlocalnotifications.default_notification_icon"
            android:resource="@mipmap/ic_launcher"/>

    </application>

    <!-- ═══════════════════════════════════════════════════════════
         QUERIES (Android 11+ requiere declarar paquetes consultados)
         ═══════════════════════════════════════════════════════════ -->
    <queries>
        <!-- Para compartir contenido via Intent -->
        <intent>
            <action android:name="android.intent.action.SEND"/>
            <data android:mimeType="*/*"/>
        </intent>
    </queries>

</manifest>
